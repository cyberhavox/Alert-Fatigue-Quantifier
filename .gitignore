# Alert Fatigue Quantifier — Repository Exclusions

# Data Directories (Preserve directory structure via .gitkeep, ignore generated logs)
data/raw/*
!data/raw/.gitkeep
data/baseline/*
!data/baseline/.gitkeep
data/output/*
!data/output/.gitkeep
data/models/*

# Python Compilation and Caching
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.coverage
htmlcov/
.cProfile/

# Virtual Environments
venv/
.venv/
env/
.env/

# Environment Configuration
.env
.env.local

# Streamlit Configurations
.streamlit/*
!.streamlit/config.toml

# IDE Settings
.vscode/
.idea/
*.swp
*.swo

# Large report artifacts (not needed for deployment)
docs/report/*.pdf
docs/report/*.docx
docs/report/*.zip
docs/report/~$*
docs/report/*.png
Research_Project_Guidelines*.pdf
package-lock.json
node_modules/

# Temp/scratch
*.pkl
data/models/*.pkl

# Project documents — not needed on GitHub
docs/
DESIGN.md
*.pdf
CLOUD_STARTUP.md
